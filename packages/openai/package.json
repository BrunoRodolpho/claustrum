{
  "name": "@claustrum/openai",
  "version": "0.1.1",
  "description": "ModelProvider adapter for the OpenAI Chat Completions API. Streaming-cancellable, tool-args stitched, error-translated, with native embeddings.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit && eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@claustrum/core": "workspace:^",
    "openai": "^4.77.0"
  },
  "devDependencies": {
    "@claustrum/core": "workspace:*",
    "@claustrum/eslint-config": "workspace:*",
    "@types/node": "^22.0.0",
    "openai": "^4.77.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
