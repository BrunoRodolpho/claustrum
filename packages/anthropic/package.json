{
  "name": "@claustrum/anthropic",
  "version": "0.1.3",
  "description": "ModelProvider adapter for the Anthropic Messages API. Streaming-cancellable, error-translated, stop-reason-normalized.",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit && eslint \"src/**/*.ts\" \"tests/**/*.ts\"",
    "test": "vitest run"
  },
  "dependencies": {
    "@claustrum/core": "workspace:*"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.82.0"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.82.0",
    "@claustrum/eslint-config": "workspace:*",
    "@types/node": "^22.0.0",
    "typescript": "^5.9.0",
    "vitest": "^3.2.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
