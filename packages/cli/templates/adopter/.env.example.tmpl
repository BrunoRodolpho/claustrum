# ${projectName} — environment variables
#
# The scaffolded conductor uses in-memory test doubles only. To switch to
# production providers, populate these and replace the relevant ports in
# `src/index.ts`.

# Anthropic model provider (replace InMemoryModelProvider stub in src/index.ts)
ANTHROPIC_API_KEY=

# OpenAI model provider (alternative to Anthropic)
OPENAI_API_KEY=

# Postgres-backed memory adapter (@claustrum/memory-postgres)
DATABASE_URL=postgres://user:pass@localhost:5432/${projectName}

# Redis (memory hot cache, session store)
REDIS_URL=redis://localhost:6379
