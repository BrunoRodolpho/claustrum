# ${projectName} — environment variables
#
# The scaffolded conductor (src/index.ts) uses in-memory test doubles only
# and reads no env vars by default. Populate the vars below when you swap
# stubs for production providers.

# ── Model providers ──────────────────────────────────────────────────────────

# Anthropic (swap InMemoryModelProvider for AnthropicProvider)
ANTHROPIC_API_KEY=

# OpenAI (alternative model provider via @claustrum/openai)
OPENAI_API_KEY=

# ── Persistence ───────────────────────────────────────────────────────────────

# Postgres (swap InMemoryMemoryProvider for @claustrum/memory-postgres)
DATABASE_URL=postgres://user:pass@localhost:5432/${projectName}

# ── WhatsApp / Twilio gateway ─────────────────────────────────────────────────
# Required when adding @claustrum/channel-whatsapp (WhatsAppChannelConfig).

# Twilio account SID + auth token (HMAC-SHA1 key for inbound webhook verification)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Gateway signing key (HMAC-SHA256) used by attest() to sign envelopes sent
# to the kernel.  Distinct from TWILIO_AUTH_TOKEN — this is the runtime ↔
# kernel secret.  Rotate via gatewayKeyId in WhatsAppChannelConfig.
GATEWAY_SIGNING_KEY=
